# EditorConfig — https://editorconfig.org
# Cross-editor consistency for RelyLoop.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,json,yaml,yml,md,css,html}]
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 4

[*.sh]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false
