{
  "name": "relyloop-ui",
  "version": "0.1.0",
  "private": true,
  "description": "RelyLoop frontend — Next.js 16 App Router",
  "scripts": {
    "prebuild": "node scripts/copy-docs.mjs",
    "predev": "node scripts/copy-docs.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "capture-guides": "playwright test -c playwright.demo.config.ts && node scripts/promote-videos.mjs",
    "types:gen": "node scripts/gen-types.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\""
  },
  "dependencies": {
    "@hookform/resolvers": "~3.10.0",
    "@radix-ui/react-alert-dialog": "~1.1.15",
    "@radix-ui/react-dialog": "~1.1.15",
    "@radix-ui/react-label": "~2.1.8",
    "@radix-ui/react-popover": "~1.1.16",
    "@radix-ui/react-select": "~2.3.0",
    "@radix-ui/react-slot": "~1.2.4",
    "@radix-ui/react-tabs": "~1.1.13",
    "@radix-ui/react-tooltip": "~1.2.9",
    "@tanstack/react-query": "~5.101.0",
    "@tanstack/react-query-devtools": "~5.101.0",
    "@tanstack/react-table": "~8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.11",
    "next-themes": "~0.4.6",
    "prism-react-renderer": "~2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "~7.76.1",
    "react-markdown": "^10.1.0",
    "recharts": "~3.8.1",
    "remark-gfm": "~4.0.1",
    "sonner": "~2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "~7.5.2",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": "^8.5.15",
      "undici@>=7.0.0 <7.28.0": "^7.28.0",
      "js-yaml@>=4.0.0 <4.2.0": "^4.2.0"
    }
  }
}
